## Content Review Workflow

### Article Status Machine
```
     [Draft] ──submit──→ [Pending] ──approve──→ [Published]
       ↑                     |
       └──(author edits)─── reject ──→ [Rejected]
```

### Business Rules
- Only **Reviewer** or **Admin** can approve/reject
- Rejection **requires** feedback text (enforce validation: min 10 chars)
- When an author edits a Rejected article, status automatically resets to `Draft`
  - This reset happens in ArticleService (Malindu's domain) — do NOT duplicate the logic here;
    the ReviewService only handles Pending → Published/Rejected transitions
- On approve: send notification to article author
- On reject: send notification to article author with the feedback text
- On submit (Pending): send notification to all users with Reviewer role

```typescript
// src/services/reviewer.service.ts
async approveArticle(articleId: string, reviewId: string, reviewerId: string): Promise<Article> {
  const article = await articleRepository.findById(articleId);
  if (!article) throw new AppError('Article not found', 404);
  if (article.status !== 'Pending') {
    throw new AppError('Only Pending articles can be approved', 400);
  }

  const approved = await articleRepository.updateStatus(articleId, 'Published');

  // update review status to approved

  // Trigger approval notification (non-blocking)
  notificationService.send({
    recipient_id: article.authorId,
    type: 'success',
    notification_reference_type: 'article'
    notification_title: 'Your review request has been approved',
    message: `Your article "${article.title}" has been approved and published!`,
    reference_id: articleId,
  }).catch(err => logger.error('Notification failed', { err }));

  return approved;
}

async rejectArticle(articleId: string, reviewId: string, reviewerId: string, feedback: string): Promise<Article> {
  if (!feedback || feedback.trim().length < 10) {
    throw new AppError('Rejection feedback must be at least 10 characters', 400);
  }

  const article = await articleRepository.findById(articleId);
  if (!article) throw new AppError('Article not found', 404);
  if (article.status !== 'Pending') {
    throw new AppError('Only Pending articles can be rejected', 400);
  }

  const rejected = await articleRepository.rejectWithFeedback(articleId, feedback);

  // update review status to rejected

  // Trigger rejection notification (non-blocking)
  notificationService.send({
    recipient_id: article.authorId,
    type: 'failure',
    notification_reference_type: 'review'
    notification_title: 'Your review request has been rejected',
    message: `Your article "${article.title}" was rejected. Feedback: ${feedback}`,
    reference_id: reviewId,
  }).catch(err => logger.error('Notification failed', { err }));

  return rejected;
}
```

