{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "strictNullChecks": true,
    "types": ["node"],
    "paths": {
      "@repo/db": ["./src"],
      "@repo/db/*": ["./src/*"]
    }
  },
  "include": ["src/index.ts", "src/client.ts"],
  "exclude": ["node_modules", "dist", "src/generated/**"]
}
