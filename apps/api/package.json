{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:nodemon": "nodemon --watch src --ext ts,js,json --exec \"tsx src/index.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node src/index.js",
    "lint": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --forceExit"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/src/**/__tests__/**/*.test.ts",
      "**/src/**/*.test.ts"
    ],
    "testEnvironmentOptions": {
      "env": {
        "NODE_ENV": "test"
      }
    }
  },
  "keywords": [],
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.17.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^3.12.7",
    "typescript": "^5.9.2"
  },
  "author": "",
  "license": "ISC"
}