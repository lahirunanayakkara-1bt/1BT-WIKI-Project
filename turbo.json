{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["src/generated/prisma/**"]
    },
    "build": {
      "dependsOn": ["^generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "dist/**",
        "src/generated/**"
      ],
      "env": [
        "VERCEL_NEON_AUTH_BASE_URL",
        "VERCEL_NEON_AUTH_COOKIE_SECRET",
        "DATABASE_URL",
        "PORT"
      ],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "sonar": {
      "dependsOn": ["test"],
      "cache": false,
      "outputs": []
    }
  }
}
