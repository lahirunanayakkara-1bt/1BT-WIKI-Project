{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma", "workspace:db"],
      "outputs": ["src/generated/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"],
      "env": [
        "VERCEL_NEON_AUTH_BASE_URL",
        "VERCEL_NEON_AUTH_COOKIE_SECRET",
        "DATABASE_URL",
        "PORT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "sonar": {
      "dependsOn": ["test"],
      "cache": false,
      "outputs": []
    }
  }
}
